{
  "name": "cherryflow",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "db:migrate": "pnpm --filter @cherryflow/api db:migrate",
    "db:status": "pnpm --filter @cherryflow/api db:status",
    "db:check": "pnpm --filter @cherryflow/api db:check",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "overrides": {
      "uuid@<11.1.1": ">=11.1.1"
    }
  }
}
