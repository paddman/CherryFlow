CHERRYFLOW_API_PORT=4000
CHERRYFLOW_API_HOST=127.0.0.1
CHERRYFLOW_WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_CHERRYFLOW_API_URL=http://localhost:4000
CHERRYFLOW_DATA_FILE=./data/cherryflow.json
CHERRYFLOW_MAX_BODY_MB=8
CHERRYFLOW_STORE=json
# true: apply pending PostgreSQL migrations before the API starts.
# false: fail startup when migrations are pending; run pnpm db:migrate during deploy.
CHERRYFLOW_AUTO_MIGRATE=true
CHERRYFLOW_RUNNER=in_process
CHERRYFLOW_ADMIN_USER=cherryflow-admin
CHERRYFLOW_ADMIN_PASSWORD=change-me
CHERRYFLOW_SESSION_DAYS=7
ML_WORKER_CONCURRENCY=1

# local | openai | openclaw
CHERRYFLOW_AI_PROVIDER=local

# OpenAI-compatible provider such as vLLM, SGLang, or Ollama proxy
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=qwen3.5-35b-a3b
OPENAI_RESPONSE_FORMAT=json_object
OPENAI_REASONING_EFFORT=
OPENAI_MAX_TOKENS=

# AI memory embeddings: local uses the zero-config deterministic fallback.
# openai calls an OpenAI-compatible POST /v1/embeddings endpoint and folds the
# returned vector into CherryFlow's 384-dimension pgvector index.
CHERRYFLOW_EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://localhost:8000/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qwen3-embedding

# Qwen -> PDF skill flow node. auto falls back to the built-in renderer when
# the Python skill or model endpoint is unavailable; required fails the run.
CHERRYFLOW_REPORT_PDF_SKILL=auto
CHERRYFLOW_REPORT_PDF_SKILL_PATH=./skill_pdf/run_report.py
CHERRYFLOW_REPORT_PDF_TIMEOUT_MS=180000
PYTHON_BIN=python3

# Optional OpenClaw HTTP bridge adapter
OPENCLAW_BRIDGE_URL=http://localhost:18790
OPENCLAW_API_TOKEN=change-me
OPENCLAW_AGENT_ID=cherryflow-ui-builder

# Phase 1 production backends
# Set CHERRYFLOW_STORE=postgres and CHERRYFLOW_RUNNER=redis to use these.
DATABASE_URL=postgresql://cherryflow:cherryflow@127.0.0.1:5432/cherryflow
REDIS_URL=redis://127.0.0.1:6379
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=cherryflow
S3_ACCESS_KEY_ID=cherryflow
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true
